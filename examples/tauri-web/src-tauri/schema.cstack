// Schema of the *remote* service this shell calls over HTTP. The schema is
// the contract — it's the same `.cstack` you'd find in the remote service's
// repo, copied here so the typed client can be generated.

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

auth Principal {
  id Int
}

model Article {
  id Int @id
  title String
  body String
  published Boolean
}
