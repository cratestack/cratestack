## TanStack Query

{% if models %}
```tsx
import {
  {{ client_class_name }},
  use{{ models[0].name }}ListQuery,
  useCreate{{ models[0].name }}Mutation,
} from "{{ package_name }}";

function {{ models[0].name }}List({ client }: { client: {{ client_class_name }} }) {
  const list = use{{ models[0].name }}ListQuery(client, {
    query: {
      fields: ["id"],
      limit: 20,
    },
    queryOptions: {
      staleTime: 30_000,
    },
  });

  const create = useCreate{{ models[0].name }}Mutation(client);

  if (list.isPending) {
    return null;
  }
  if (list.isError) {
    return <ErrorState error={list.error} />;
  }

  return <ListView data={list.data} onCreate={(input) => create.mutate(input)} />;
}
```
{% endif %}

## React Native

React Native app runtimes provide `fetch`; pass the mobile API origin and keep auth token lookup in your app layer.

```ts
export function createClient(accessToken: string | null) {
  return new {{ client_class_name }}(process.env.EXPO_PUBLIC_API_ORIGIN!, {
    basePath: "{{ base_path }}",
    headers: {
      ...(accessToken ? { authorization: `Bearer ${accessToken}` } : {}),
      "x-client": "vaam-mobile",
    },
  });
}
```
