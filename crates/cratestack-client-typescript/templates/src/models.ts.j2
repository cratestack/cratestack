import type { JsonValue } from "./runtime";

// Mirrors cratestack-core::page::{Page, PageInfo} exactly — this is
// the literal wire shape every `@@paged` list route serializes with
// `#[serde(rename_all = "camelCase")]`, not an independently designed
// client-side type. Keep field names and optionality in lockstep with
// that struct; do not add/rename fields here without changing it
// there first.
export interface PageInfo {
  limit: number | null;
  offset: number | null;
  hasNextPage: boolean;
  hasPreviousPage: boolean;
}

export interface Page<T> {
  items: T[];
  totalCount: number | null;
  pageInfo: PageInfo;
}

{% for enum in enums %}
export type {{ enum.name }} = {{ enum.union }};
export const {{ enum.name }}Values = [
{% for value in enum.values %}
  "{{ value }}",
{% endfor %}
] as const satisfies readonly {{ enum.name }}[];

{% endfor %}
{% for interface in interfaces %}
export interface {{ interface.name }} {
{% if interface.has_fields %}
{% for field in interface.fields %}
  {{ field.property }}{% if field.optional %}?{% endif %}: {{ field.type_name }};
{% endfor %}
{% endif %}
}

{% endfor %}
