datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

auth SessionUser {
  id Int
  role String
  email String
}

// Model names are `AdvancedUser`/`AdvancedPost` (not `User`/`Post`) so
// their auto-derived tables (`advanced_users`/`advanced_posts`) don't
// collide with the unrelated `users`/`posts` tables `policy_db.rs`
// creates (from `blog.cstack`) against the same shared test Postgres —
// same fix-up as the `customers` collision between
// `banking_soft_delete.rs` and `views_pg_integration.rs`.
model AdvancedUser {
  id Int @id
  email String
  banned Boolean

  @@allow("read", auth() != null)
}

model AdvancedPost {
  id Int @id
  title String
  published Boolean
  authorId Int
  author AdvancedUser @relation(fields:[authorId],references:[id])

  @@deny("read", author.banned)
  @@allow("read", auth() != null && published)
  @@allow("read", author.email == auth().email)
  @@allow("update", auth() == author && auth().role == "admin")
}

type ApprovePostInput {
  postId Int
  publishNow Boolean
}

type ReviewPostInput {
  postId Int
  publishNow Boolean
  dryRun Boolean
  ownerEmail String
  mirrorEmail String
}

mutation procedure approvePost(args: ApprovePostInput): AdvancedPost
  @allow(auth() != null && auth().role == "admin" && publishNow)
  @deny(postId == 2)

mutation procedure reviewPost(args: ReviewPostInput): AdvancedPost
  @allow((auth() == null && args.dryRun) || (auth().role == "admin" && args.publishNow && args.ownerEmail == auth().email))
  @deny(args.postId == 2 || args.ownerEmail != auth().email || args.ownerEmail != args.mirrorEmail)
