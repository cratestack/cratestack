import 'package:flutter_riverpod/flutter_riverpod.dart';

import 'models.dart';
import 'queries.dart';
import 'runtime.dart';

class {{ client_class_name }} {
  {{ client_class_name }}(this._adapter, {this.basePath = '{{ base_path_literal }}'});

  final CratestackClientAdapter _adapter;
  final String basePath;

  Future<Object?> execute(
    String method,
    String path, {
    Object? body,
    Map<String, Object?>? queryParameters,
    CratestackCallOptions? options,
  }) {
    return _adapter.execute(
      CratestackRequest(
        method: method,
        path: '$basePath$path',
        queryParameters: queryParameters,
        body: body,
      ),
      options: options,
    );
  }

{% for accessor in model_accessors %}
  {{ accessor.api_class_name }} get {{ accessor.accessor }} => {{ accessor.api_class_name }}(this);
{% endfor %}
  ProceduresApi get procedures => ProceduresApi(this);
}

final {{ provider_prefix }}AdapterProvider = Provider<CratestackClientAdapter>((ref) {
  throw UnimplementedError('Override {{ provider_prefix }}AdapterProvider before reading the generated CrateStack client.');
});

final {{ provider_prefix }}BasePathProvider = Provider<String>((ref) => '{{ base_path_literal }}');

final {{ provider_prefix }}ClientProvider = Provider<{{ client_class_name }}>((ref) {
  return {{ client_class_name }}(
    ref.watch({{ provider_prefix }}AdapterProvider),
    basePath: ref.watch({{ provider_prefix }}BasePathProvider),
  );
});

{% for accessor in model_accessors %}
final {{ accessor.provider_name }} = Provider<{{ accessor.api_class_name }}>((ref) {
  return ref.watch({{ provider_prefix }}ClientProvider).{{ accessor.accessor }};
});

{% endfor %}
final {{ provider_prefix }}ProceduresApiProvider = Provider<ProceduresApi>((ref) {
  return ref.watch({{ provider_prefix }}ClientProvider).procedures;
});

{% for model in model_apis %}
class {{ model.api_class_name }} {
  const {{ model.api_class_name }}(this._client);

  final {{ client_class_name }} _client;

  Future<{{ model.list_return_type }}> list({
    CratestackListQuery? query,
    CratestackCallOptions? options,
  }) async {
    final body = await _client.execute(
      'GET',
      '{{ model.route }}',
      queryParameters: query?.toQueryParameters(),
      options: options,
    );
    return {{ model.list_decode_expr }};
  }

  Future<{% if model.is_paged %}Page<T>{% else %}List<T>{% endif %}> listView<T>({
    required CratestackProjection<T> projection,
    CratestackListQuery? query,
    CratestackCallOptions? options,
  }) async {
    final body = await _client.execute(
      'GET',
      '{{ model.route }}',
      queryParameters: cratestackMergeFetchIntoListQuery(query, projection.toFetchQuery()).toQueryParameters(),
      options: options,
    );
{% if model.is_paged %}
    return Page<T>.fromWire(
      cratestackAsValueMap(body),
      decodeItem: (item) => projection.fromWire(cratestackAsValueMap(item)),
    );
{% else %}
    return cratestackAsValueList(body)
        .map((item) => projection.fromWire(cratestackAsValueMap(item)))
        .toList(growable: false);
{% endif %}
  }

  Future<{{ model.model_name }}> get({{ model.primary_key_type }} id, {
    CratestackFetchQuery? query,
    CratestackCallOptions? options,
  }) async {
    final body = await _client.execute(
      'GET',
      '{{ model.detail_route }}',
      queryParameters: query?.toQueryParameters(),
      options: options,
    );
    return {{ model.model_name }}.fromWire(cratestackAsValueMap(body));
  }

  Future<T> getView<T>({{ model.primary_key_type }} id, {
    required CratestackProjection<T> projection,
    CratestackCallOptions? options,
  }) async {
    final body = await _client.execute(
      'GET',
      '{{ model.detail_route }}',
      queryParameters: projection.toFetchQuery().toQueryParameters(),
      options: options,
    );
    return projection.fromWire(cratestackAsValueMap(body));
  }

  Future<{{ model.model_name }}> create({{ model.create_input_name }} input, {
    CratestackCallOptions? options,
  }) async {
    final body = await _client.execute(
      'POST',
      '{{ model.route }}',
      body: input.toWire(),
      options: options,
    );
    return {{ model.model_name }}.fromWire(cratestackAsValueMap(body));
  }

  Future<{{ model.model_name }}> update({{ model.primary_key_type }} id, {{ model.update_input_name }} input, {
    CratestackCallOptions? options,
  }) async {
    final body = await _client.execute(
      'PATCH',
      '{{ model.detail_route }}',
      body: input.toWire(),
      options: options,
    );
    return {{ model.model_name }}.fromWire(cratestackAsValueMap(body));
  }

  Future<{{ model.model_name }}> delete({{ model.primary_key_type }} id, {
    CratestackCallOptions? options,
  }) async {
    final body = await _client.execute(
      'DELETE',
      '{{ model.detail_route }}',
      options: options,
    );
    return {{ model.model_name }}.fromWire(cratestackAsValueMap(body));
  }
}

{% endfor %}
class ProceduresApi {
  const ProceduresApi(this._client);

  final {{ client_class_name }} _client;

{% for procedure in procedures %}
  Future<{{ procedure.return_type }}> {{ procedure.method_name }}({{ procedure.args_name }} args, {
    CratestackCallOptions? options,
  }) async {
    final body = await _client.execute(
      'POST',
      '{{ procedure.route }}',
      body: args.toWire(),
      options: options,
    );
    return {{ procedure.return_decode_expr }};
  }

{% endfor %}
}
