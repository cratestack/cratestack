datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

auth SessionUser {
  id Int
  email String
  orgSlug String
}

model Organization {
  id Int @id
  slug String

  @@allow("read", auth() != null)
}

model User {
  id Int @id
  email String
  banned Boolean

  @@allow("read", auth() != null)
}

model Project {
  id Int @id
  name String
  organizationId Int
  organization Organization @relation(fields:[organizationId],references:[id])
  memberships Membership[] @relation(fields:[id],references:[projectId])

  @@allow("read", auth() != null)
}

model Membership {
  id Int @id
  projectId Int
  userId Int
  active Boolean
  blocked Boolean
  project Project @relation(fields:[projectId],references:[id])
  user User @relation(fields:[userId],references:[id])

  @@allow("read", auth() != null)
}

model Task {
  id Int @id @default(dbgenerated())
  title String
  projectId Int
  project Project @relation(fields:[projectId],references:[id])

  @@deny("read", project.memberships.some.user.banned)
  @@allow("read", project.organization.slug == auth().orgSlug && project.memberships.some.user.email == auth().email)
  @@allow("update", project.memberships.some.user.email == auth().email)
  @@allow("delete", project.memberships.every.active)
  @@allow("create", project.organization.slug == auth().orgSlug && project.memberships.some.user.email == auth().email && project.memberships.none.blocked)
}

model AutoTask {
  id Int @id @default(dbgenerated())
  title String
  projectId Int @default(dbgenerated())
  project Project @relation(fields:[projectId],references:[id])

  @@allow("create", project.organization.slug == auth().orgSlug && project.memberships.some.user.email == auth().email && project.memberships.none.blocked)
}
