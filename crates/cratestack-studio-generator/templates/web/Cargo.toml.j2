[package]
name = "{{ workspace.web_crate_name }}"
version = "0.1.0"
edition = "{{ workspace.rust_edition }}"

[dependencies]
gloo-net = "0.6"
serde = { version = "1", features = ["derive"] }
serde_json = "1"
wasm-bindgen-futures = "0.4"
wasm-bindgen = "0.2"
web-sys = { version = "0.3", features = ["HtmlInputElement", "HtmlSelectElement", "HtmlTextAreaElement", "KeyboardEvent", "UrlSearchParams"] }
yew = { version = "0.21", features = ["csr"] }
yew-router = "0.18"
{{ workspace.shared_crate_name }} = { path = "../shared" }
