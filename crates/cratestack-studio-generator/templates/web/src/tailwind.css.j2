@import "tailwindcss";
@source "./index.html";
@source "./src";
@plugin "daisyui";
@plugin "daisyui/theme" {
  name: "cratestack-studio";
  default: true;
  prefersdark: false;
  color-scheme: light;

  --color-base-100: #ffffff;
  --color-base-200: #f6ede6;
  --color-base-300: #e8ddd5;
  --color-base-content: #0f1724;
  --color-primary: #c8682a;
  --color-primary-content: #ffffff;
  --color-secondary: #f6ede6;
  --color-secondary-content: #3a2e2a;
  --color-accent: #e3b77a;
  --color-accent-content: #24170f;
  --color-neutral: #f8f4f1;
  --color-neutral-content: #46382f;
  --color-info: #6787a9;
  --color-info-content: #ffffff;
  --color-success: #2f9e4e;
  --color-success-content: #ffffff;
  --color-warning: #e08b00;
  --color-warning-content: #1b1208;
  --color-error: #d6453b;
  --color-error-content: #ffffff;
  --radius-selector: 0.375rem;
  --radius-field: 0.375rem;
  --radius-box: 0.5rem;
  --border: 1px;
  --depth: 0;
  --noise: 0;
}

:root {
  --background: #fbf7f3;
  --foreground: #0f1724;
  --border: #00000014;
  --input: #ffffff;
  --primary: #c8682a;
  --primary-foreground: #ffffff;
  --secondary: #f6ede6;
  --secondary-foreground: #3a2e2a;
  --muted: #f0e9e5;
  --muted-foreground: #8a7f7a;
  --success: #2f9e4e;
  --success-foreground: #ffffff;
  --accent: #e3b77a;
  --accent-foreground: #24170f;
  --destructive: #d6453b;
  --destructive-foreground: #ffffff;
  --warning: #e08b00;
  --warning-foreground: #1b1208;
  --card: #ffffff;
  --card-foreground: #0f1724;
  --sidebar: #f8f4f1;
  --sidebar-foreground: #46382f;
  --sidebar-primary: #c8682a;
  --sidebar-primary-foreground: #ffffff;
  --radius-sm: 4px;
  --radius-md: 6px;
  --radius-lg: 8px;
  --radius-xl: 12px;
}

* {
  box-sizing: border-box;
}

html,
body,
#app {
  width: 100%;
  height: 100%;
}

body {
  margin: 0;
  font-family:
    Inter,
    ui-sans-serif,
    system-ui,
    -apple-system,
    BlinkMacSystemFont,
    "Segoe UI",
    sans-serif;
  background: var(--background);
  color: var(--foreground);
  overflow: hidden;
}

button,
input,
select,
textarea {
  font: inherit;
}

.monospace {
  font-family:
    ui-monospace,
    SFMono-Regular,
    Menlo,
    Monaco,
    Consolas,
    "Liberation Mono",
    "Courier New",
    monospace;
}

.studio-app {
  display: flex;
  width: 100%;
  height: 100dvh;
  overflow: hidden;
  background: var(--background);
}

.studio-main-shell {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
  min-height: 0;
  position: relative;
}

.studio-global-sidebar {
  width: 64px;
  background: var(--sidebar);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16px 0 12px;
  gap: 14px;
  flex-shrink: 0;
}

.studio-brand-mark {
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--sidebar-foreground);
}

.studio-global-nav-button {
  width: 40px;
  height: 40px;
  border: 0;
  background: transparent;
  color: var(--sidebar-foreground);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: background-color 140ms ease, color 140ms ease;
}

.studio-global-nav-button:hover,
.studio-global-nav-button:focus-visible {
  background: color-mix(in srgb, var(--sidebar-primary) 12%, white);
  outline: none;
}

.studio-global-nav-button.is-active {
  background: var(--sidebar-primary);
  color: var(--sidebar-primary-foreground);
}

.studio-global-nav-bottom {
  margin-top: auto;
}

.studio-avatar-chip {
  width: 28px;
  height: 28px;
  border-radius: 999px;
  border: 2px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  font-weight: 700;
  color: #ffffff;
  background: linear-gradient(135deg, #c8682a, #8c4b24);
}

.studio-topbar {
  height: 56px;
  border-bottom: 1px solid var(--border);
  background: var(--background);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 0 16px;
  flex-shrink: 0;
}

.studio-breadcrumbs {
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
  font-weight: 500;
}

.studio-project-selector {
  min-width: 0;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px 12px;
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  background: var(--background);
  color: var(--foreground);
  cursor: pointer;
}

.studio-breadcrumb-separator {
  color: var(--muted-foreground);
}

.studio-top-actions,
.studio-toolbar-actions {
  display: flex;
  align-items: center;
  gap: 12px;
}

.studio-action-button,
.studio-primary-button,
.studio-toolbar-button,
.studio-toolbar-button-primary,
.studio-icon-button,
.studio-tab-button,
.studio-subtab-button,
.studio-tree-node {
  border: 0;
  background: transparent;
}

.studio-action-button,
.studio-toolbar-button {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--muted);
  color: var(--foreground);
  padding: 6px 12px;
  border-radius: var(--radius-md);
  font-size: 13px;
  font-weight: 500;
  border: 1px solid var(--border);
  cursor: pointer;
}

.studio-primary-button,
.studio-toolbar-button-primary {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--primary);
  color: var(--primary-foreground);
  padding: 8px 16px;
  border-radius: var(--radius-md);
  font-size: 14px;
  font-weight: 500;
  cursor: pointer;
}

.studio-icon-button {
  width: 28px;
  height: 28px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-md);
  color: var(--muted-foreground);
  cursor: pointer;
}

.studio-action-button:hover,
.studio-toolbar-button:hover,
.studio-icon-button:hover,
.studio-project-selector:hover,
.studio-primary-button:hover,
.studio-toolbar-button-primary:hover,
.studio-tab-button:hover,
.studio-subtab-button:hover,
.studio-tree-node:hover {
  filter: brightness(0.98);
}

.studio-workspace {
  flex: 1;
  min-height: 0;
  min-width: 0;
  display: flex;
}

.studio-object-explorer {
  width: 280px;
  border-right: 1px solid var(--border);
  background: var(--background);
  display: flex;
  flex-direction: column;
  min-height: 0;
  flex-shrink: 0;
}

.studio-explorer-header {
  padding: 16px;
  border-bottom: 1px solid var(--border);
  font-size: 14px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.studio-explorer-search {
  padding: 12px 16px;
  border-bottom: 1px solid var(--border);
}

.studio-search-input {
  display: flex;
  align-items: center;
  gap: 8px;
  width: 100%;
  background: var(--input);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 6px 12px;
}

.studio-search-input input {
  width: 100%;
  border: 0;
  background: transparent;
  outline: none;
  color: var(--foreground);
  font-size: 13px;
}

.studio-tree-scroll {
  flex: 1;
  overflow-y: auto;
  padding: 8px 0;
}

.studio-tree-node {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 6px 16px;
  font-size: 13px;
  color: var(--foreground);
  cursor: pointer;
  text-align: left;
}

.studio-tree-node.is-active {
  background: var(--muted);
  font-weight: 500;
}

.studio-tree-node-section,
.studio-tree-node-passive {
  cursor: default;
}

.studio-tree-node-spaced {
  margin-top: 8px;
}

.studio-tree-indent {
  width: 16px;
  flex-shrink: 0;
}

.studio-tree-icon {
  width: 14px;
  height: 14px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: var(--muted-foreground);
  flex-shrink: 0;
}

.studio-tree-node.is-active .studio-tree-icon {
  color: var(--foreground);
}

.studio-tree-badge {
  margin-left: auto;
  font-size: 11px;
  background: var(--muted);
  color: var(--muted-foreground);
  padding: 2px 6px;
  border-radius: var(--radius-sm);
}

.studio-editor-view {
  flex: 1;
  min-width: 0;
  min-height: 0;
  display: flex;
  flex-direction: column;
  background: var(--background);
}

.studio-editor-tabs {
  display: flex;
  align-items: stretch;
  gap: 0;
  padding: 0 16px;
  border-bottom: 1px solid var(--border);
  overflow-x: auto;
  flex-shrink: 0;
}

.studio-tab-button {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 16px;
  color: var(--muted-foreground);
  border-bottom: 2px solid transparent;
  font-size: 14px;
  white-space: nowrap;
  cursor: pointer;
}

.studio-tab-button.is-active {
  color: var(--foreground);
  border-bottom-color: var(--primary);
  font-weight: 500;
}

.studio-subtabs {
  display: flex;
  align-items: center;
  gap: 24px;
  padding: 12px 24px;
  border-bottom: 1px solid var(--border);
  overflow-x: auto;
  flex-shrink: 0;
}

.studio-subtab-button {
  color: var(--muted-foreground);
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  white-space: nowrap;
}

.studio-subtab-button.is-active {
  color: var(--foreground);
}

.studio-editor-toolbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  padding: 16px 24px;
  flex-shrink: 0;
}

.studio-toolbar-title {
  font-size: 14px;
  font-weight: 500;
  color: var(--foreground);
}

.studio-editor-content {
  flex: 1;
  min-height: 0;
  overflow: auto;
  padding: 0 24px 24px;
}

.studio-surface {
  background: var(--card);
  color: var(--card-foreground);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
}

.studio-summary-grid {
  display: grid;
  gap: 16px;
}

.studio-summary-cards {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.studio-summary-card {
  padding: 14px 16px;
}

.studio-summary-label {
  font-size: 12px;
  font-weight: 600;
  color: var(--muted-foreground);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.studio-summary-value {
  margin-top: 8px;
  font-size: 28px;
  font-weight: 600;
  line-height: 1;
}

.studio-summary-sections {
  display: grid;
  gap: 16px;
  grid-template-columns: 1.25fr 0.9fr;
}

.studio-card {
  padding: 16px;
}

.studio-card-title {
  font-size: 16px;
  font-weight: 600;
}

.studio-card-copy {
  margin-top: 6px;
  color: var(--muted-foreground);
  font-size: 13px;
  line-height: 1.5;
}

.studio-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.studio-badge,
.studio-type-badge,
.studio-soft-badge,
.studio-status-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 2px 6px;
  border-radius: var(--radius-sm);
  font-size: 12px;
  line-height: 1.4;
}

.studio-badge,
.studio-soft-badge,
.studio-type-badge {
  background: var(--muted);
  color: var(--muted-foreground);
}

.studio-badge.is-accent {
  background: var(--primary);
  color: var(--primary-foreground);
}

.studio-type-badge.is-enum {
  background: var(--primary);
  color: var(--primary-foreground);
}

.studio-status-badge.is-success {
  background: color-mix(in srgb, var(--success) 14%, white);
  color: var(--success);
}

.studio-status-badge.is-error {
  background: color-mix(in srgb, var(--destructive) 12%, white);
  color: var(--destructive);
}

.studio-list-stack {
  display: grid;
  gap: 12px;
}

.studio-list-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
  padding: 12px 14px;
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  background: #fffdfb;
}

.studio-list-title {
  font-size: 14px;
  font-weight: 600;
}

.studio-list-meta {
  margin-top: 4px;
  font-size: 12px;
  color: var(--muted-foreground);
}

.studio-data-table-wrap {
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--card);
}

.studio-data-table {
  width: 100%;
  border-collapse: collapse;
}

.studio-data-table th {
  text-align: left;
  padding: 12px 16px;
  font-size: 12px;
  font-weight: 600;
  color: var(--muted-foreground);
  background: var(--muted);
  border-bottom: 1px solid var(--border);
  text-transform: uppercase;
  letter-spacing: 0.04em;
}

.studio-data-table td {
  padding: 12px 16px;
  font-size: 13px;
  color: var(--foreground);
  border-bottom: 1px solid var(--border);
  vertical-align: top;
}

.studio-data-table tr:last-child td {
  border-bottom: 0;
}

.studio-schema-empty,
.studio-empty-state {
  border: 1px dashed var(--border);
  border-radius: var(--radius-md);
  padding: 14px 16px;
  color: var(--muted-foreground);
  font-size: 13px;
}

.studio-add-row {
  margin-top: 16px;
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px;
  border: 1px dashed var(--border);
  border-radius: var(--radius-md);
  color: var(--muted-foreground);
  font-size: 13px;
  font-weight: 500;
}

.studio-checkbox-visual {
  width: 16px;
  height: 16px;
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  color: transparent;
}

.studio-checkbox-visual.is-checked {
  background: var(--primary);
  border-color: var(--primary);
  color: var(--primary-foreground);
}

.studio-center-cell {
  text-align: center;
}

.studio-mono-muted {
  color: var(--muted-foreground);
}

.studio-form-grid {
  display: grid;
  gap: 16px;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.studio-form-field {
  display: grid;
  gap: 8px;
  padding: 14px;
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  background: var(--card);
}

.studio-form-field.is-wide {
  grid-column: 1 / -1;
}

.studio-field-label {
  font-size: 13px;
  font-weight: 600;
}

.studio-field-meta {
  font-size: 12px;
  color: var(--muted-foreground);
}

.studio-input,
.studio-select,
.studio-textarea {
  width: 100%;
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  background: var(--input);
  color: var(--foreground);
  padding: 8px 10px;
  font-size: 13px;
}

.studio-textarea {
  min-height: 120px;
  resize: vertical;
}

.studio-checkbox-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16px;
}

.studio-help-text {
  font-size: 12px;
  color: var(--muted-foreground);
}

.studio-code-block {
  margin: 0;
  padding: 16px;
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  background: #f7f0ea;
  color: var(--foreground);
  font-size: 12px;
  line-height: 1.6;
  overflow: auto;
}

.studio-loading-screen {
  width: 100%;
  height: 100dvh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--background);
  padding: 24px;
}

.studio-loading-card {
  min-width: 280px;
  max-width: 420px;
  display: grid;
  gap: 8px;
  padding: 20px;
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  background: var(--card);
}

.studio-loading-card-error {
  color: var(--destructive);
}

@media (max-width: 1100px) {
  .studio-object-explorer {
    width: 248px;
  }

  .studio-summary-cards,
  .studio-summary-sections {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 900px) {
  .studio-object-explorer {
    display: none;
  }

  .studio-editor-toolbar,
  .studio-editor-content,
  .studio-subtabs {
    padding-left: 16px;
    padding-right: 16px;
  }

  .studio-summary-cards,
  .studio-summary-sections,
  .studio-form-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 640px) {
  .studio-topbar {
    padding: 0 12px;
  }

  .studio-breadcrumbs {
    gap: 6px;
  }

  .studio-top-actions {
    gap: 8px;
  }

  .studio-action-button span,
  .studio-primary-button span {
    display: none;
  }
}
