use wasm_bindgen_futures::spawn_local;
use web_sys::HtmlInputElement;
use yew::prelude::*;
use yew_router::prelude::*;

use crate::{
    api::fetch_metadata,
    components::{
        icons::{Icon, IconName},
        layout::{Layout, RailMode},
        metadata_drawer::MetadataDrawer,
        sidebar::NavItem,
    },
    pages::{
        api::ApiPage,
        model_list::ModelListPage,
        procedures::ProcedurePage,
        query::QueryPage,
        schema::SchemaPage,
    },
    routes::Route,
    state::{LoadState, MetadataDrawerState},
};
use {{ workspace.shared_crate_lib_name }}::{StudioContextMetadata, StudioMetadata};

#[derive(Clone, PartialEq)]
struct QueryTab {
    id: u32,
    title: String,
    context_key: String,
}

#[function_component(App)]
pub fn app() -> Html {
    let metadata_state = use_state(|| LoadState::<StudioMetadata>::Loading);
    let metadata_drawer = use_state(|| MetadataDrawerState::Hidden);
    let explorer_filter = use_state(String::new);
    let explorer_search_ref = use_node_ref();
    let model_search_ref = use_node_ref();
    let query_tabs = use_state(Vec::<QueryTab>::new);
    let next_query_id = use_state(|| 1_u32);

    {
        let metadata_state = metadata_state.clone();
        use_effect_with((), move |_| {
            spawn_local(async move {
                match fetch_metadata().await {
                    Ok(metadata) => metadata_state.set(LoadState::Loaded(metadata)),
                    Err(error) => metadata_state.set(LoadState::Error(error)),
                }
            });
            || ()
        });
    }

    match &*metadata_state {
        LoadState::Loading | LoadState::Idle => html! {
            <div class="studio-loading-screen" data-theme="cratestack-studio">
                <div class="studio-loading-card">
                    <div class="font-semibold">{ "Loading Studio metadata" }</div>
                    <div class="text-sm text-[var(--muted-foreground)]">{ "Reading generated schema metadata and preparing the workspace." }</div>
                </div>
            </div>
        },
        LoadState::Error(error) => html! {
            <div class="studio-loading-screen" data-theme="cratestack-studio">
                <div class="studio-loading-card studio-loading-card-error">{ error }</div>
            </div>
        },
        LoadState::Loaded(metadata) => html! {
            <BrowserRouter>
                <StudioWorkspace
                    metadata={metadata.clone()}
                    metadata_drawer={metadata_drawer.clone()}
                    explorer_filter={explorer_filter.clone()}
                    explorer_search_ref={explorer_search_ref.clone()}
                    model_search_ref={model_search_ref.clone()}
                    query_tabs={query_tabs.clone()}
                    next_query_id={next_query_id.clone()}
                />
            </BrowserRouter>
        },
    }
}

#[derive(Properties, PartialEq)]
struct StudioWorkspaceProps {
    metadata: StudioMetadata,
    metadata_drawer: UseStateHandle<MetadataDrawerState>,
    explorer_filter: UseStateHandle<String>,
    explorer_search_ref: NodeRef,
    model_search_ref: NodeRef,
    query_tabs: UseStateHandle<Vec<QueryTab>>,
    next_query_id: UseStateHandle<u32>,
}

#[function_component(StudioWorkspace)]
fn studio_workspace(props: &StudioWorkspaceProps) -> Html {
    let navigator = use_navigator().expect("router navigator should exist");
    let route = use_route::<Route>().unwrap_or(Route::StudioRoot);

    {
        let navigator = navigator.clone();
        let default_context_key = props.metadata.default_context().map(|context| context.key.clone());
        use_effect_with(route.clone(), move |route| {
            if matches!(route, Route::StudioRoot | Route::StudioRootSlash | Route::NotFound) {
                if let Some(context_key) = default_context_key.clone() {
                    navigator.push(&Route::Overview {
                        context: context_key,
                    });
                }
            }
            || ()
        });
    }

    {
        let query_tabs = props.query_tabs.clone();
        use_effect_with(route.clone(), move |route| {
            if let Route::Query { context, id } = route {
                if !query_tabs.iter().any(|query| query.id == *id) {
                    let mut next_tabs = (*query_tabs).clone();
                    next_tabs.push(QueryTab {
                        id: *id,
                        title: format!("Query {id}"),
                        context_key: context.clone(),
                    });
                    query_tabs.set(next_tabs);
                }
            }
            || ()
        });
    }

    let Some(context) = current_context(&props.metadata, &route) else {
        return html! {
            <div class="studio-loading-screen" data-theme="cratestack-studio">
                <div class="studio-loading-card studio-loading-card-error">{ "No schema contexts were generated for this Studio workspace." }</div>
            </div>
        };
    };

    let selected_nav = nav_from_route(&route);
    let rail_mode = rail_mode_from_route(&route);
    let (title, subtitle) = header_context(&props.metadata, &context, &route, &props.query_tabs);
    let metadata_visible = matches!(*props.metadata_drawer, MetadataDrawerState::Visible);
    let context_key = context.key.clone();

    let on_select_nav = {
        let navigator = navigator.clone();
        let context_key = context_key.clone();
        Callback::from(move |nav_item: NavItem| {
            navigator.push(&route_from_nav(nav_item, &context_key))
        })
    };
    let on_select_context = {
        let navigator = navigator.clone();
        Callback::from(move |next_context_key: String| {
            navigator.push(&Route::Overview {
                context: next_context_key,
            });
        })
    };
    let on_toggle_metadata = {
        let metadata_drawer = props.metadata_drawer.clone();
        Callback::from(move |_| {
            metadata_drawer.set(match &*metadata_drawer {
                MetadataDrawerState::Hidden => MetadataDrawerState::Visible,
                MetadataDrawerState::Visible => MetadataDrawerState::Hidden,
            });
        })
    };
    let on_explorer_filter = {
        let explorer_filter = props.explorer_filter.clone();
        Callback::from(move |event: InputEvent| {
            let value = event.target_unchecked_into::<HtmlInputElement>().value();
            explorer_filter.set(value);
        })
    };
    let on_focus_search = {
        let route = route.clone();
        let explorer_search_ref = props.explorer_search_ref.clone();
        let model_search_ref = props.model_search_ref.clone();
        Callback::from(move |_| {
            let target = match route {
                Route::Model { .. } => model_search_ref.cast::<HtmlInputElement>(),
                _ => explorer_search_ref.cast::<HtmlInputElement>(),
            };
            if let Some(input) = target {
                let _ = input.focus();
                input.select();
            }
        })
    };
    let on_new_query = {
        let navigator = navigator.clone();
        let query_tabs = props.query_tabs.clone();
        let next_query_id = props.next_query_id.clone();
        let context_key = context_key.clone();
        Callback::from(move |_| {
            let id = *next_query_id;
            let mut next_tabs = (*query_tabs).clone();
            next_tabs.push(QueryTab {
                id,
                title: format!("Query {id}"),
                context_key: context_key.clone(),
            });
            query_tabs.set(next_tabs);
            next_query_id.set(id + 1);
            navigator.push(&Route::Query {
                context: context_key.clone(),
                id,
            });
        })
    };

    let editor_tabs = render_editor_tabs(&route, &context, &props.query_tabs, navigator.clone());
    let metadata_panel = html! {
        <MetadataDrawer workspace={props.metadata.clone()} context={context.clone()} visible={metadata_visible} on_close={on_toggle_metadata.clone()} />
    };

    let content = switch_route(route, &props.metadata, &context, props.model_search_ref.clone());

    html! {
        <Layout
            workspace={props.metadata.clone()}
            context={context}
            selected_nav={selected_nav}
            rail_mode={rail_mode}
            title={title}
            subtitle={subtitle}
            explorer_filter={(*props.explorer_filter).clone()}
            on_explorer_filter={on_explorer_filter}
            search_input_ref={props.explorer_search_ref.clone()}
            metadata_panel={metadata_panel}
            editor_tabs={editor_tabs}
            on_select_nav={on_select_nav}
            on_select_context={on_select_context}
            on_focus_search={on_focus_search}
            on_toggle_metadata={on_toggle_metadata}
            on_new_query={on_new_query}
        >
            { content }
        </Layout>
    }
}

fn current_context(metadata: &StudioMetadata, route: &Route) -> Option<StudioContextMetadata> {
    let context_key = route_context_key(route)
        .map(str::to_owned)
        .or_else(|| metadata.default_context().map(|context| context.key.clone()))?;
    metadata.context(&context_key).cloned()
}

fn route_context_key(route: &Route) -> Option<&str> {
    match route {
        Route::Overview { context }
        | Route::Model { context, .. }
        | Route::Procedure { context, .. }
        | Route::Api { context }
        | Route::Query { context, .. } => Some(context.as_str()),
        Route::StudioRoot | Route::StudioRootSlash | Route::NotFound => None,
    }
}

fn switch_route(
    route: Route,
    workspace: &StudioMetadata,
    context: &StudioContextMetadata,
    model_search_ref: NodeRef,
) -> Html {
    match route {
        Route::StudioRoot | Route::StudioRootSlash | Route::Overview { .. } => {
            html! { <SchemaPage workspace={workspace.clone()} context={context.clone()} /> }
        }
        Route::Model { model, .. } => html! {
            <ModelListPage
                context={context.clone()}
                selected_model_name={Some(model)}
                search_input_ref={model_search_ref}
            />
        },
        Route::Procedure { procedure, .. } => html! {
            <ProcedurePage context={context.clone()} procedure_name={procedure} />
        },
        Route::Api { .. } => html! { <ApiPage workspace={workspace.clone()} context={context.clone()} /> },
        Route::Query { id, .. } => {
            html! { <QueryPage context={context.clone()} query_id={id} /> }
        }
        Route::NotFound => html! { <SchemaPage workspace={workspace.clone()} context={context.clone()} /> },
    }
}

fn render_editor_tabs(
    route: &Route,
    context: &StudioContextMetadata,
    query_tabs: &UseStateHandle<Vec<QueryTab>>,
    navigator: Navigator,
) -> Html {
    let route = route.clone();
    let query_tabs_handle = query_tabs.clone();
    let current_context_key = context.key.clone();

    html! {
        <div class="studio-editor-tabs">
            {
                match &route {
                    Route::StudioRoot | Route::StudioRootSlash | Route::Overview { .. } => html! {
                        <button class="studio-tab-button is-active" type="button">
                            <Icon name={IconName::FileCode} class="h-4 w-4 text-[var(--primary)]" />
                            <span>{ format!("{}.overview", context.service) }</span>
                        </button>
                    },
                    Route::Model { model, .. } => {
                        let label = context.models.iter().find(|item| item.name == *model).map(|item| format!("public.{}", item.display_name)).unwrap_or_else(|| format!("public.{model}"));
                        html! {
                            <button class="studio-tab-button is-active" type="button">
                                <Icon name={IconName::Table} class="h-4 w-4 text-[var(--primary)]" />
                                <span>{ label }</span>
                            </button>
                        }
                    }
                    Route::Procedure { procedure, .. } => {
                        let label = context.procedures.iter().find(|item| item.name == *procedure).map(|item| format!("{} (Procedure)", item.display_name)).unwrap_or_else(|| format!("{procedure} (Procedure)"));
                        html! {
                            <button class="studio-tab-button is-active" type="button">
                                <Icon name={IconName::TerminalSquare} class="h-4 w-4 text-[var(--primary)]" />
                                <span>{ label }</span>
                            </button>
                        }
                    }
                    Route::Api { .. } => html! {
                        <button class="studio-tab-button is-active" type="button">
                            <Icon name={IconName::Activity} class="h-4 w-4 text-[var(--primary)]" />
                            <span>{ "API Explorer" }</span>
                        </button>
                    },
                    Route::Query { .. } => html! {},
                    Route::NotFound => html! {},
                }
            }

            { for query_tabs.iter().filter(|tab| tab.context_key == current_context_key).map(|tab| {
                let is_active = matches!(&route, Route::Query { id, context } if *id == tab.id && *context == tab.context_key);
                let tab_route = Route::Query { context: tab.context_key.clone(), id: tab.id };
                let open_navigator = navigator.clone();
                let close_navigator = navigator.clone();
                let query_tabs_handle = query_tabs_handle.clone();
                let current_route = route.clone();
                let current_context_key = current_context_key.clone();
                let tab_id = tab.id;
                let onclick = Callback::from(move |_| open_navigator.push(&tab_route));
                let onclose = Callback::from(move |event: MouseEvent| {
                    event.stop_propagation();
                    let mut next_tabs = (*query_tabs_handle).clone();
                    next_tabs.retain(|query| query.id != tab_id);
                    query_tabs_handle.set(next_tabs.clone());
                    if matches!(current_route, Route::Query { id, .. } if id == tab_id) {
                        if let Some(next_tab) = next_tabs.iter().rev().find(|tab| tab.context_key == current_context_key) {
                            close_navigator.push(&Route::Query { context: next_tab.context_key.clone(), id: next_tab.id });
                        } else {
                            close_navigator.push(&Route::Overview { context: current_context_key.clone() });
                        }
                    }
                });
                html! {
                    <button class={classes!("studio-tab-button", is_active.then_some("is-active"))} type="button" {onclick}>
                        <Icon name={IconName::FileCode} class="h-4 w-4" />
                        <span>{ tab.title.clone() }</span>
                        <span class="inline-flex items-center" onclick={onclose}>
                            <Icon name={IconName::X} class="h-3.5 w-3.5" />
                        </span>
                    </button>
                }
            }) }
        </div>
    }
}

fn route_from_nav(item: NavItem, context: &str) -> Route {
    match item {
        NavItem::Overview => Route::Overview {
            context: context.to_owned(),
        },
        NavItem::Model(model) => Route::Model {
            context: context.to_owned(),
            model,
        },
        NavItem::Procedure(procedure) => Route::Procedure {
            context: context.to_owned(),
            procedure,
        },
        NavItem::Query(id) => Route::Query {
            context: context.to_owned(),
            id,
        },
        NavItem::Api => Route::Api {
            context: context.to_owned(),
        },
    }
}

fn nav_from_route(route: &Route) -> NavItem {
    match route {
        Route::StudioRoot | Route::StudioRootSlash | Route::Overview { .. } | Route::NotFound => {
            NavItem::Overview
        }
        Route::Model { model, .. } => NavItem::Model(model.clone()),
        Route::Procedure { procedure, .. } => NavItem::Procedure(procedure.clone()),
        Route::Api { .. } => NavItem::Api,
        Route::Query { id, .. } => NavItem::Query(*id),
    }
}

fn rail_mode_from_route(route: &Route) -> RailMode {
    match route {
        Route::StudioRoot | Route::StudioRootSlash | Route::Overview { .. } | Route::NotFound => {
            RailMode::Overview
        }
        Route::Model { .. } | Route::Procedure { .. } => RailMode::Explorer,
        Route::Query { .. } => RailMode::Query,
        Route::Api { .. } => RailMode::Api,
    }
}

fn header_context(
    workspace: &StudioMetadata,
    context: &StudioContextMetadata,
    route: &Route,
    query_tabs: &UseStateHandle<Vec<QueryTab>>,
) -> (String, String) {
    match route {
        Route::StudioRoot | Route::StudioRootSlash | Route::Overview { .. } | Route::NotFound => {
            ("Overview".to_owned(), context.schema_path.clone())
        }
        Route::Model { model, .. } => context
            .models
            .iter()
            .find(|item| item.name == *model)
            .map(|item| (item.display_name.clone(), item.resource_path.clone()))
            .unwrap_or_else(|| (model.clone(), "Generated model view".to_owned())),
        Route::Procedure { procedure, .. } => context
            .procedures
            .iter()
            .find(|item| item.name == *procedure)
            .map(|item| (item.display_name.clone(), item.route_path.clone()))
            .unwrap_or_else(|| (procedure.clone(), "Generated procedure view".to_owned())),
        Route::Api { .. } => (
            "API Explorer".to_owned(),
            format!("{} mounted routes", workspace.mount_path),
        ),
        Route::Query { id, .. } => (
            query_tabs
                .iter()
                .find(|query| query.id == *id)
                .map(|query| query.title.clone())
                .unwrap_or_else(|| format!("Query {id}")),
            format!("Ad-hoc query testing for {}", context.display_name),
        ),
    }
}
