use wasm_bindgen_futures::spawn_local;
use web_sys::HtmlInputElement;
use yew::prelude::*;

use crate::{
    api::fetch_model_list,
    components::{
        icons::{Icon, IconName},
        json_view::JsonView,
        table::DataTable,
    },
    state::LoadState,
};
use {{ workspace.shared_crate_lib_name }}::{
    StudioContextMetadata, StudioField, StudioModel, StudioProxyResponse,
};

#[derive(Clone, Copy, PartialEq, Eq)]
enum ModelTab {
    Columns,
    Data,
    Relations,
    Raw,
}

#[derive(Properties, PartialEq)]
pub struct ModelListPageProps {
    pub context: StudioContextMetadata,
    pub selected_model_name: Option<String>,
    pub search_input_ref: NodeRef,
}

#[function_component(ModelListPage)]
pub fn model_list_page(props: &ModelListPageProps) -> Html {
    let list_state = use_state(|| LoadState::<StudioProxyResponse>::Idle);
    let tab = use_state(|| ModelTab::Columns);
    let search_query = use_state(String::new);

    {
        let list_state = list_state.clone();
        let tab = tab.clone();
        let search_query = search_query.clone();
        let selected_model_name = props.selected_model_name.clone();
        let context_key = props.context.key.clone();
        use_effect_with(selected_model_name.clone(), move |selected_model_name| {
            tab.set(ModelTab::Columns);
            search_query.set(String::new());
            if let Some(model_name) = selected_model_name.clone() {
                list_state.set(LoadState::Loading);
                spawn_local(async move {
                    match fetch_model_list(&context_key, &model_name, None).await {
                        Ok(response) => list_state.set(LoadState::Loaded(response)),
                        Err(error) => list_state.set(LoadState::Error(error)),
                    }
                });
            }
            || ()
        });
    }

    let selected_model = props
        .selected_model_name
        .as_ref()
        .and_then(|name| props.context.models.iter().find(|model| &model.name == name));

    let Some(model) = selected_model.cloned() else {
        return html! { <div class="studio-empty-state">{ "Pick a model from the explorer." }</div> };
    };

    let on_run_search = {
        let list_state = list_state.clone();
        let selected_model_name = props.selected_model_name.clone();
        let search_query = search_query.clone();
        let context_key = props.context.key.clone();
        Callback::from(move |_| {
            if let Some(model_name) = selected_model_name.clone() {
                let query = (*search_query).clone();
                let context_key = context_key.clone();
                list_state.set(LoadState::Loading);
                let list_state = list_state.clone();
                spawn_local(async move {
                    match fetch_model_list(&context_key, &model_name, Some(&query)).await {
                        Ok(response) => list_state.set(LoadState::Loaded(response)),
                        Err(error) => list_state.set(LoadState::Error(error)),
                    }
                });
            }
        })
    };

    let raw_json = match &*list_state {
        LoadState::Loaded(response) => serde_json::to_string_pretty(response).unwrap_or_else(|_| "{}".to_owned()),
        LoadState::Error(error) => error.clone(),
        _ => "{}".to_owned(),
    };

    html! {
        <>
            <div class="studio-subtabs">
                { render_subtab(&tab, ModelTab::Columns, "Columns") }
                { render_subtab(&tab, ModelTab::Data, "Data") }
                { render_subtab(&tab, ModelTab::Relations, "Foreign Keys") }
                { render_subtab(&tab, ModelTab::Raw, "Raw") }
            </div>

            <div class="studio-editor-toolbar">
                <div class="studio-toolbar-title">
                    {
                        match *tab {
                            ModelTab::Columns => "Table Schema",
                            ModelTab::Data => "Table Data",
                            ModelTab::Relations => "Relation Map",
                            ModelTab::Raw => "Raw Payload",
                        }
                    }
                </div>
                <div class="studio-toolbar-actions">
                    <input
                        ref={props.search_input_ref.clone()}
                        class="studio-input w-[220px]"
                        type="text"
                        value={(*search_query).clone()}
                        placeholder="Search rows..."
                        oninput={ {
                            let search_query = search_query.clone();
                            Callback::from(move |event: InputEvent| {
                                let value = event.target_unchecked_into::<HtmlInputElement>().value();
                                search_query.set(value);
                            })
                        } }
                    />
                    <button class="studio-toolbar-button" type="button" onclick={on_run_search.clone()}>
                        <Icon name={IconName::Search} class="h-3.5 w-3.5" />
                        <span>{ "Search" }</span>
                    </button>
                    <button class="studio-toolbar-button" type="button">
                        <Icon name={IconName::History} class="h-3.5 w-3.5" />
                        <span>{ "History" }</span>
                    </button>
                    <button class="studio-toolbar-button" type="button">
                        <Icon name={IconName::Plus} class="h-3.5 w-3.5" />
                        <span>{ "Add Column" }</span>
                    </button>
                    <button class="studio-toolbar-button-primary" type="button" onclick={on_run_search.clone()}>
                        { "Refresh" }
                    </button>
                </div>
            </div>

            <div class="studio-editor-content">
                {
                    match *tab {
                        ModelTab::Columns => render_columns_view(&model),
                        ModelTab::Data => render_data_view(&model, &list_state),
                        ModelTab::Relations => render_relations_view(&model),
                        ModelTab::Raw => html! { <JsonView text={raw_json} /> },
                    }
                }
            </div>
        </>
    }
}

fn render_subtab(current: &UseStateHandle<ModelTab>, target: ModelTab, label: &'static str) -> Html {
    let current = current.clone();
    let active = *current == target;
    html! {
        <button
            class={classes!("studio-subtab-button", active.then_some("is-active"))}
            type="button"
            onclick={Callback::from(move |_| current.set(target))}
        >
            { label }
        </button>
    }
}

fn render_columns_view(model: &StudioModel) -> Html {
    html! {
        <>
            <div class="studio-data-table-wrap">
                <table class="studio-data-table">
                    <thead>
                        <tr>
                            <th class="w-10">{ "" }</th>
                            <th>{ "Name" }</th>
                            <th>{ "Type" }</th>
                            <th>{ "Default Value" }</th>
                            <th class="studio-center-cell">{ "Primary" }</th>
                            <th class="studio-center-cell">{ "Nullable" }</th>
                            <th class="studio-center-cell">{ "Unique" }</th>
                            <th class="w-20">{ "" }</th>
                        </tr>
                    </thead>
                    <tbody>
                        { for model.scalar_fields.iter().map(|field| render_column_row(model, field)) }
                    </tbody>
                </table>
            </div>

            <div class="studio-add-row">
                <Icon name={IconName::Plus} class="h-4 w-4" />
                <span>{ format!("Add a new column to {}", model.display_name) }</span>
            </div>
        </>
    }
}

fn render_column_row(model: &StudioModel, field: &StudioField) -> Html {
    let is_primary = field.name == model.primary_key;
    let is_nullable = !field.required;
    let is_unique = is_primary;

    html! {
        <tr>
            <td>
                <div class="flex items-center justify-center text-[var(--muted-foreground)]">
                    <Icon name={IconName::GripVertical} class="h-4 w-4" />
                </div>
            </td>
            <td>
                <span class="monospace font-semibold">{ field.name.clone() }</span>
            </td>
            <td>
                <span class={if field.enum_name.is_some() { classes!("studio-type-badge", "monospace", "is-enum") } else { classes!("studio-type-badge", "monospace") }}>
                    { field.type_name.clone() }
                </span>
            </td>
            <td>
                <span class="monospace studio-mono-muted">{ if field.required { "-" } else { "NULL" } }</span>
            </td>
            <td class="studio-center-cell">
                {
                    if is_primary {
                        html! { <span class="inline-flex items-center justify-center text-[#e0a21d]"><Icon name={IconName::Key} class="h-4 w-4" /></span> }
                    } else {
                        html! {}
                    }
                }
            </td>
            <td class="studio-center-cell">{ render_checkbox(is_nullable) }</td>
            <td class="studio-center-cell">{ render_checkbox(is_unique) }</td>
            <td>
                <div class="flex items-center justify-center gap-2 text-[var(--muted-foreground)]">
                    <button class="studio-icon-button" type="button" aria-label="Column settings">
                        <Icon name={IconName::Sliders} class="h-4 w-4" />
                    </button>
                    <button class="studio-icon-button" type="button" aria-label="Delete column">
                        <Icon name={IconName::Trash2} class="h-4 w-4" />
                    </button>
                </div>
            </td>
        </tr>
    }
}

fn render_checkbox(checked: bool) -> Html {
    html! {
        <span class={classes!("studio-checkbox-visual", checked.then_some("is-checked"))}>
            { if checked { html! { <Icon name={IconName::Check} class="h-3 w-3" /> } } else { html! {} } }
        </span>
    }
}

fn render_data_view(model: &StudioModel, state: &UseStateHandle<LoadState<StudioProxyResponse>>) -> Html {
    match &**state {
        LoadState::Idle | LoadState::Loading => html! {
            <div class="studio-empty-state">{ format!("Loading rows for {}...", model.display_name) }</div>
        },
        LoadState::Error(error) => html! {
            <div class="studio-empty-state">{ error.clone() }</div>
        },
        LoadState::Loaded(response) => {
            let rows = response
                .data
                .as_ref()
                .map(rows_from_value)
                .unwrap_or_default();
            if rows.is_empty() {
                html! {
                    <div class="studio-empty-state">{ "No rows returned. The upstream service may be empty or still protected by auth." }</div>
                }
            } else {
                html! {
                    <DataTable columns={model.list_columns.clone()} rows={rows} primary_key={Some(model.primary_key.clone())} />
                }
            }
        }
    }
}

fn render_relations_view(model: &StudioModel) -> Html {
    if model.relations.is_empty() {
        return html! {
            <div class="studio-empty-state">{ "This model does not expose relation metadata." }</div>
        };
    }

    html! {
        <div class="studio-surface studio-card">
            <div class="studio-card-title">{ "Relations" }</div>
            <p class="studio-card-copy">{ "Generated relationship metadata for this model." }</p>
            <div class="mt-4 studio-list-stack">
                { for model.relations.iter().map(|relation| html! {
                    <div class="studio-list-row">
                        <div>
                            <div class="studio-list-title monospace">{ relation.name.clone() }</div>
                            <div class="studio-list-meta">{ relation.target_model.clone() }</div>
                        </div>
                        <span class="studio-soft-badge">{ relation.cardinality.clone() }</span>
                    </div>
                }) }
            </div>
        </div>
    }
}

fn rows_from_value(value: &serde_json::Value) -> Vec<serde_json::Value> {
    match value {
        serde_json::Value::Array(rows) => rows.clone(),
        serde_json::Value::Object(object) => object
            .get("items")
            .and_then(|items| items.as_array())
            .cloned()
            .unwrap_or_default(),
        _ => Vec::new(),
    }
}
