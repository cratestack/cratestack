use std::collections::BTreeMap;

use wasm_bindgen_futures::spawn_local;
use yew::prelude::*;

use crate::{
    api::invoke_procedure,
    components::{
        icons::{Icon, IconName},
        json_view::JsonView,
        table::DataTable,
    },
};
use {{ workspace.shared_crate_lib_name }}::{
    StudioContextMetadata, StudioInputField, StudioProcedure, StudioProxyResponse,
};

#[derive(Clone, PartialEq)]
enum FieldValue {
    Text(String),
    Bool(bool),
}

#[derive(Clone, Copy, PartialEq, Eq)]
enum ProcedureTab {
    Inputs,
    Response,
    Raw,
}

#[derive(Properties, PartialEq)]
pub struct ProcedurePageProps {
    pub context: StudioContextMetadata,
    pub procedure_name: String,
}

#[function_component(ProcedurePage)]
pub fn procedure_page(props: &ProcedurePageProps) -> Html {
    let response_state = use_state(|| None::<Result<StudioProxyResponse, String>>);
    let tab = use_state(|| ProcedureTab::Inputs);

    let Some(procedure) = props
        .context
        .procedures
        .iter()
        .find(|procedure| procedure.name == props.procedure_name)
        .cloned()
    else {
        return html! { <div class="studio-empty-state">{ "Unknown procedure." }</div> };
    };

    let form_state = use_state(|| initial_form_state(&procedure));

    {
        let form_state = form_state.clone();
        let response_state = response_state.clone();
        let tab = tab.clone();
        let procedure = procedure.clone();
        use_effect_with(props.procedure_name.clone(), move |_| {
            form_state.set(initial_form_state(&procedure));
            response_state.set(None);
            tab.set(ProcedureTab::Inputs);
            || ()
        });
    }

    let on_submit = {
        let procedure = procedure.clone();
        let form_state = form_state.clone();
        let response_state = response_state.clone();
        let tab = tab.clone();
        let context_key = props.context.key.clone();
        Callback::from(move |_| {
            let procedure = procedure.clone();
            let values = (*form_state).clone();
            let response_state = response_state.clone();
            let tab = tab.clone();
            let context_key = context_key.clone();
            spawn_local(async move {
                match build_payload(&procedure.payload_mode, &procedure.input_fields, &values) {
                    Ok(body) => {
                        let result = invoke_procedure(&context_key, &procedure.name, body).await;
                        response_state.set(Some(result));
                        tab.set(ProcedureTab::Response);
                    }
                    Err(error) => response_state.set(Some(Err(error))),
                }
            });
        })
    };

    let on_reset = {
        let form_state = form_state.clone();
        let response_state = response_state.clone();
        let tab = tab.clone();
        let procedure = procedure.clone();
        Callback::from(move |_| {
            form_state.set(initial_form_state(&procedure));
            response_state.set(None);
            tab.set(ProcedureTab::Inputs);
        })
    };

    let raw = response_state
        .as_ref()
        .and_then(|result| result.as_ref().ok())
        .map(|response| serde_json::to_string_pretty(response).unwrap_or_else(|_| "{}".to_owned()))
        .unwrap_or_else(|| "{}".to_owned());

    html! {
        <>
            <div class="studio-subtabs">
                { render_procedure_subtab(&tab, ProcedureTab::Inputs, "Inputs") }
                { render_procedure_subtab(&tab, ProcedureTab::Response, "Response") }
                { render_procedure_subtab(&tab, ProcedureTab::Raw, "Raw") }
            </div>

            <div class="studio-editor-toolbar">
                <div class="studio-toolbar-title">{ procedure.display_name.clone() }</div>
                <div class="studio-toolbar-actions">
                    <button class="studio-toolbar-button" type="button" onclick={on_reset}>
                        <Icon name={IconName::History} class="h-3.5 w-3.5" />
                        <span>{ "Reset" }</span>
                    </button>
                    <button class="studio-toolbar-button-primary" type="button" onclick={on_submit}>{ "Run Procedure" }</button>
                </div>
            </div>

            <div class="studio-editor-content">
                {
                    match *tab {
                        ProcedureTab::Inputs => render_inputs_view(&procedure, &form_state),
                        ProcedureTab::Response => render_response_view(&response_state),
                        ProcedureTab::Raw => html! { <JsonView text={raw} /> },
                    }
                }
            </div>
        </>
    }
}

fn render_procedure_subtab(
    current: &UseStateHandle<ProcedureTab>,
    target: ProcedureTab,
    label: &'static str,
) -> Html {
    let current = current.clone();
    let active = *current == target;
    html! {
        <button
            class={classes!("studio-subtab-button", active.then_some("is-active"))}
            type="button"
            onclick={Callback::from(move |_| current.set(target))}
        >
            { label }
        </button>
    }
}

fn render_inputs_view(
    procedure: &StudioProcedure,
    form_state: &UseStateHandle<BTreeMap<String, FieldValue>>,
) -> Html {
    html! {
        <div class="studio-summary-grid">
            <div class="studio-surface studio-card">
                <div class="studio-card-title">{ "Procedure details" }</div>
                <div class="mt-4 studio-chip-row">
                    <span class={if procedure.kind == "mutation" { classes!("studio-badge", "is-accent") } else { classes!("studio-soft-badge") }}>
                        { procedure.kind.clone() }
                    </span>
                    <span class="studio-soft-badge monospace">{ procedure.route_path.clone() }</span>
                    <span class="studio-soft-badge">{ format!("returns {}", procedure.return_type) }</span>
                </div>
            </div>

            {
                if procedure.input_fields.is_empty() {
                    html! { <div class="studio-empty-state">{ "This procedure does not require any input fields." }</div> }
                } else {
                    html! {
                        <div class="studio-form-grid">
                            { for procedure.input_fields.iter().map(|field| render_input_field(field, form_state)) }
                        </div>
                    }
                }
            }
        </div>
    }
}

fn render_response_view(state: &UseStateHandle<Option<Result<StudioProxyResponse, String>>>) -> Html {
    match state.as_ref() {
        None => html! {
            <div class="studio-empty-state">{ "Run the procedure to inspect its response." }</div>
        },
        Some(Err(error)) => html! {
            <div class="studio-empty-state">{ error.clone() }</div>
        },
        Some(Ok(response)) => {
            let rows = response
                .data
                .as_ref()
                .map(rows_from_response)
                .unwrap_or_default();
            let columns = columns_from_rows(&rows);

            html! {
                <div class="studio-summary-grid">
                    <div class="studio-summary-cards">
                        <div class="studio-surface studio-summary-card">
                            <div class="studio-summary-label">{ "Status" }</div>
                            <div class="studio-summary-value">{ response.status }</div>
                        </div>
                        <div class="studio-surface studio-summary-card">
                            <div class="studio-summary-label">{ "Rows" }</div>
                            <div class="studio-summary-value">{ rows.len() }</div>
                        </div>
                        <div class="studio-surface studio-summary-card">
                            <div class="studio-summary-label">{ "Method" }</div>
                            <div class="studio-summary-value text-[16px] leading-6">{ response.request.method.clone() }</div>
                        </div>
                        <div class="studio-surface studio-summary-card">
                            <div class="studio-summary-label">{ "Result" }</div>
                            <div class="studio-summary-value text-[16px] leading-6">{ if response.ok { "Success" } else { "Error" } }</div>
                        </div>
                    </div>

                    <div class="studio-surface studio-card">
                        <div class="studio-card-title">{ "Response preview" }</div>
                        <p class="studio-card-copy monospace">{ response.request.upstream_url.clone() }</p>
                        <div class="mt-4">
                            {
                                if !rows.is_empty() && !columns.is_empty() {
                                    html! { <DataTable columns={columns} rows={rows} /> }
                                } else {
                                    html! { <div class="studio-empty-state">{ "No tabular rows were inferred from the response payload." }</div> }
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        }
    }
}

fn render_input_field(
    field: &StudioInputField,
    form_state: &UseStateHandle<BTreeMap<String, FieldValue>>,
) -> Html {
    let label = if field.required {
        format!("{} *", field.display_name)
    } else {
        field.display_name.clone()
    };

    if field.is_boolean {
        let checked = matches!(form_state.get(&field.name), Some(FieldValue::Bool(true)));
        let form_state = form_state.clone();
        let field_name = field.name.clone();
        return html! {
            <div class="studio-form-field">
                <div class="studio-checkbox-row">
                    <div>
                        <div class="studio-field-label">{ label }</div>
                        <div class="studio-field-meta">{ field.type_name.clone() }</div>
                    </div>
                    <input
                        type="checkbox"
                        checked={checked}
                        onchange={Callback::from(move |event: Event| {
                            let checked = event.target_unchecked_into::<web_sys::HtmlInputElement>().checked();
                            let mut next = (*form_state).clone();
                            next.insert(field_name.clone(), FieldValue::Bool(checked));
                            form_state.set(next);
                        })}
                    />
                </div>
            </div>
        };
    }

    let current_value = match form_state.get(&field.name) {
        Some(FieldValue::Text(value)) => value.clone(),
        _ => String::new(),
    };
    let form_state = form_state.clone();
    let field_name = field.name.clone();

    let help_text = if !field.enum_values.is_empty() {
        Some(format!("Pick one of: {}", field.enum_values.join(", ")))
    } else if field.is_json {
        Some("Enter valid JSON.".to_owned())
    } else if field.list {
        Some("Enter one item per line.".to_owned())
    } else if field.is_number {
        Some("Numbers only.".to_owned())
    } else {
        None
    };

    let field_classes = classes!(
        "studio-form-field",
        (field.is_json || field.list).then_some("is-wide")
    );

    if !field.enum_values.is_empty() {
        return html! {
            <div class={field_classes}>
                <div class="studio-field-label">{ label }</div>
                <div class="studio-field-meta">{ field.type_name.clone() }</div>
                <select
                    class="studio-select"
                    value={current_value.clone()}
                    onchange={Callback::from(move |event: Event| {
                        let value = event.target_unchecked_into::<web_sys::HtmlSelectElement>().value();
                        let mut next = (*form_state).clone();
                        next.insert(field_name.clone(), FieldValue::Text(value));
                        form_state.set(next);
                    })}
                >
                    <option value="">{ if field.required { "Choose an option" } else { "Leave empty" } }</option>
                    { for field.enum_values.iter().map(|value| html! {
                        <option value={value.clone()}>{ value.clone() }</option>
                    }) }
                </select>
                { help_text.map(|text| html! { <div class="studio-help-text">{ text }</div> }).unwrap_or_default() }
            </div>
        };
    }

    if field.is_json || field.list {
        return html! {
            <div class={field_classes}>
                <div class="studio-field-label">{ label }</div>
                <div class="studio-field-meta">{ field.type_name.clone() }</div>
                <textarea
                    class="studio-textarea monospace"
                    value={current_value.clone()}
                    oninput={Callback::from(move |event: InputEvent| {
                        let value = event.target_unchecked_into::<web_sys::HtmlTextAreaElement>().value();
                        let mut next = (*form_state).clone();
                        next.insert(field_name.clone(), FieldValue::Text(value));
                        form_state.set(next);
                    })}
                />
                { help_text.map(|text| html! { <div class="studio-help-text">{ text }</div> }).unwrap_or_default() }
            </div>
        };
    }

    let input_type = if field.is_number { "number" } else { "text" };

    html! {
        <div class={field_classes}>
            <div class="studio-field-label">{ label }</div>
            <div class="studio-field-meta">{ field.type_name.clone() }</div>
            <input
                type={input_type}
                class="studio-input"
                value={current_value}
                oninput={Callback::from(move |event: InputEvent| {
                    let value = event.target_unchecked_into::<web_sys::HtmlInputElement>().value();
                    let mut next = (*form_state).clone();
                    next.insert(field_name.clone(), FieldValue::Text(value));
                    form_state.set(next);
                })}
            />
            { help_text.map(|text| html! { <div class="studio-help-text">{ text }</div> }).unwrap_or_default() }
        </div>
    }
}

fn initial_form_state(procedure: &StudioProcedure) -> BTreeMap<String, FieldValue> {
    let mut state = BTreeMap::<String, FieldValue>::new();
    for field in &procedure.input_fields {
        if field.is_boolean {
            state.insert(field.name.clone(), FieldValue::Bool(false));
        } else {
            state.insert(field.name.clone(), FieldValue::Text(String::new()));
        }
    }
    state
}

fn rows_from_response(value: &serde_json::Value) -> Vec<serde_json::Value> {
    match value {
        serde_json::Value::Array(rows) => rows.clone(),
        serde_json::Value::Object(object) => object
            .get("items")
            .and_then(|items| items.as_array())
            .cloned()
            .or_else(|| {
                if object.values().all(|value| !value.is_object()) {
                    Some(vec![value.clone()])
                } else {
                    None
                }
            })
            .unwrap_or_default(),
        _ => Vec::new(),
    }
}

fn columns_from_rows(rows: &[serde_json::Value]) -> Vec<String> {
    rows.first()
        .and_then(|row| row.as_object())
        .map(|object| object.keys().cloned().collect())
        .unwrap_or_default()
}

fn build_payload(
    payload_mode: &str,
    fields: &[StudioInputField],
    values: &BTreeMap<String, FieldValue>,
) -> Result<serde_json::Value, String> {
    let mut object = serde_json::Map::new();
    for field in fields {
        let value = values.get(&field.name);
        let wire = build_field_value(field, value)?;
        if let Some(wire) = wire {
            object.insert(field.name.clone(), wire);
        }
    }

    Ok(match payload_mode {
        "wrapped_args_object" => serde_json::json!({ "args": serde_json::Value::Object(object) }),
        "flat" => serde_json::Value::Object(object),
        _ => serde_json::json!({}),
    })
}

fn build_field_value(
    field: &StudioInputField,
    value: Option<&FieldValue>,
) -> Result<Option<serde_json::Value>, String> {
    if field.is_boolean {
        let checked = matches!(value, Some(FieldValue::Bool(true)));
        return Ok(Some(serde_json::Value::Bool(checked)));
    }

    let text = match value {
        Some(FieldValue::Text(text)) => text.trim(),
        _ => "",
    };

    if text.is_empty() {
        if field.required {
            return Err(format!("Field '{}' is required.", field.display_name));
        }
        return Ok(None);
    }

    if field.is_json {
        let parsed = serde_json::from_str::<serde_json::Value>(text)
            .map_err(|error| format!("Field '{}' must be valid JSON: {error}", field.display_name))?;
        return Ok(Some(parsed));
    }

    if field.list {
        let items = text
            .lines()
            .map(str::trim)
            .filter(|item| !item.is_empty())
            .map(|item| {
                if field.is_number {
                    parse_numeric_value(item, &field.display_name)
                } else {
                    Ok(serde_json::Value::String(item.to_owned()))
                }
            })
            .collect::<Result<Vec<_>, String>>()?;
        return Ok(Some(serde_json::Value::Array(items)));
    }

    if field.is_number {
        return Ok(Some(parse_numeric_value(text, &field.display_name)?));
    }

    Ok(Some(serde_json::Value::String(text.to_owned())))
}

fn parse_numeric_value(value: &str, display_name: &str) -> Result<serde_json::Value, String> {
    if value.contains(['.', 'e', 'E']) {
        let parsed = value
            .parse::<f64>()
            .map_err(|error| format!("Field '{display_name}' must be a number: {error}"))?;
        let number = serde_json::Number::from_f64(parsed)
            .ok_or_else(|| format!("Field '{display_name}' must be a finite number."))?;
        Ok(serde_json::Value::Number(number))
    } else {
        value
            .parse::<i64>()
            .map(|parsed| serde_json::Value::Number(parsed.into()))
            .map_err(|error| format!("Field '{display_name}' must be a number: {error}"))
    }
}
