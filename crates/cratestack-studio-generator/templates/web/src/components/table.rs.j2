use yew::prelude::*;

#[derive(Properties, PartialEq)]
pub struct DataTableProps {
    pub columns: Vec<String>,
    pub rows: Vec<serde_json::Value>,
    #[prop_or_default]
    pub primary_key: Option<String>,
}

#[function_component(DataTable)]
pub fn data_table(props: &DataTableProps) -> Html {
    html! {
        <div class="studio-data-table-wrap overflow-x-auto">
            <table class="studio-data-table">
                <thead>
                    <tr>
                        { for props.columns.iter().map(|column| html! {
                            <th>{ column }</th>
                        }) }
                    </tr>
                </thead>
                <tbody>
                    { for props.rows.iter().map(|row| {
                        let object = row.as_object();
                        html! {
                            <tr>
                                { for props.columns.iter().map(|column| {
                                    let value = object.and_then(|object| object.get(column));
                                    let primary_key = props.primary_key.as_deref() == Some(column.as_str());
                                    html! { <td class="align-top">{ render_value(value, primary_key) }</td> }
                                }) }
                            </tr>
                        }
                    }) }
                </tbody>
            </table>
        </div>
    }
}

fn render_value(value: Option<&serde_json::Value>, primary_key: bool) -> Html {
    match value {
        None => html! { <span class="studio-mono-muted">{ "-" }</span> },
        Some(serde_json::Value::Null) => html! { <span class="studio-mono-muted">{ "null" }</span> },
        Some(serde_json::Value::Bool(value)) => {
            let class = if *value {
                classes!("studio-status-badge", "is-success")
            } else {
                classes!("studio-soft-badge")
            };
            html! { <span class={class}>{ value.to_string() }</span> }
        }
        Some(serde_json::Value::Number(value)) => html! { <span class="font-medium">{ value.to_string() }</span> },
        Some(serde_json::Value::String(value)) if primary_key => {
            html! { <code class="studio-type-badge monospace">{ value.clone() }</code> }
        }
        Some(serde_json::Value::String(value)) => html! { <span>{ value.clone() }</span> },
        Some(serde_json::Value::Array(value)) => {
            html! {
                <code class="monospace studio-mono-muted block max-w-[20rem] overflow-hidden text-ellipsis whitespace-nowrap text-xs">
                    { serde_json::to_string(value).unwrap_or_else(|_| "<unrenderable>".to_owned()) }
                </code>
            }
        }
        Some(serde_json::Value::Object(value)) => {
            html! {
                <code class="monospace studio-mono-muted block max-w-[20rem] overflow-hidden text-ellipsis whitespace-nowrap text-xs">
                    { serde_json::to_string(value).unwrap_or_else(|_| "<unrenderable>".to_owned()) }
                </code>
            }
        }
    }
}
