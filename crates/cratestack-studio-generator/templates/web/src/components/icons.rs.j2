use yew::prelude::*;

#[derive(Clone, PartialEq)]
pub enum IconName {
    Activity,
    Check,
    ChevronDown,
    ChevronRight,
    Code2,
    Database,
    Dashboard,
    FileCode,
    FolderOpen,
    GripVertical,
    History,
    Key,
    MoreHorizontal,
    Plus,
    Search,
    Server,
    Settings,
    Sliders,
    Table,
    TerminalSquare,
    Trash2,
    X,
}

#[derive(Properties, PartialEq)]
pub struct IconProps {
    pub name: IconName,
    #[prop_or_else(|| AttrValue::from("h-4 w-4"))]
    pub class: AttrValue,
}

#[function_component(Icon)]
pub fn icon(props: &IconProps) -> Html {
    html! {
        <svg
            aria-hidden="true"
            class={props.class.clone()}
            fill="none"
            focusable="false"
            stroke="currentColor"
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="1.8"
            viewBox="0 0 24 24"
        >
            { icon_paths(&props.name) }
        </svg>
    }
}

