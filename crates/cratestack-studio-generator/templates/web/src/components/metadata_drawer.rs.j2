use yew::prelude::*;

use crate::components::json_view::JsonView;
use {{ workspace.shared_crate_lib_name }}::{StudioContextMetadata, StudioMetadata};

#[derive(Properties, PartialEq)]
pub struct MetadataDrawerProps {
    pub workspace: StudioMetadata,
    pub context: StudioContextMetadata,
    pub visible: bool,
    pub on_close: Callback<MouseEvent>,
}

#[function_component(MetadataDrawer)]
pub fn metadata_drawer(props: &MetadataDrawerProps) -> Html {
    if !props.visible {
        return html! {};
    }

    let raw = serde_json::to_string_pretty(&props.context).unwrap_or_else(|_| "{}".to_owned());

    html! {
        <>
            <button class="fixed inset-0 z-30 bg-black/10" type="button" aria-label="Close metadata" onclick={props.on_close.clone()}></button>
            <aside class="fixed inset-y-0 right-0 z-40 flex w-full max-w-[320px] flex-col border-l border-[var(--border)] bg-[var(--card)] shadow-sm">
                <div class="border-b border-[var(--border)] px-4 py-3">
                    <div class="flex items-center justify-between gap-3">
                        <div>
                            <div class="text-sm font-semibold tracking-tight">{ "Metadata" }</div>
                            <div class="mt-1 text-xs text-[var(--muted-foreground)] monospace">{ props.context.schema_path.clone() }</div>
                        </div>
                        <button class="studio-icon-button" type="button" aria-label="Close metadata" onclick={props.on_close.clone()}>
                            { "Close" }
                        </button>
                    </div>
                </div>

                <div class="grid gap-3 overflow-y-auto p-4">
                    <div class="studio-summary-cards grid-cols-3">
                        <div class="studio-surface studio-summary-card px-3 py-3">
                            <div class="studio-summary-label">{ "Models" }</div>
                            <div class="studio-summary-value text-[22px]">{ props.context.models.len() }</div>
                        </div>
                        <div class="studio-surface studio-summary-card px-3 py-3">
                            <div class="studio-summary-label">{ "Procs" }</div>
                            <div class="studio-summary-value text-[22px]">{ props.context.procedures.len() }</div>
                        </div>
                        <div class="studio-surface studio-summary-card px-3 py-3">
                            <div class="studio-summary-label">{ "Enums" }</div>
                            <div class="studio-summary-value text-[22px]">{ props.context.enums.len() }</div>
                        </div>
                    </div>

                    <div class="studio-surface studio-card">
                        <div class="studio-card-title text-sm">{ "Mount path" }</div>
                        <div class="studio-card-copy monospace">{ props.workspace.mount_path.clone() }</div>
                    </div>

                    <div class="studio-surface studio-card">
                        <div class="studio-card-title text-sm">{ "Raw metadata" }</div>
                        <div class="mt-3">
                            <JsonView text={raw} />
                        </div>
                    </div>
                </div>
            </aside>
        </>
    }
}
