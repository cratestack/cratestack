#[derive(Debug, Clone)]
pub struct StudioConfig {
    pub mount_path: String,
    pub bind_addr: String,
    pub static_dir: String,
    #[allow(dead_code)]
    pub enable_dev_context_override: bool,
}

impl StudioConfig {
    pub fn from_env() -> Self {
        Self {
            mount_path: {{ app.mount_path|tojson }}.to_owned(),
            bind_addr: std::env::var("STUDIO_BIND_ADDR")
                .unwrap_or_else(|_| {{ backend.bind_addr_default|tojson }}.to_owned()),
            static_dir: std::env::var("STUDIO_STATIC_DIR")
                .unwrap_or_else(|_| {{ backend.static_dir_default|tojson }}.to_owned()),
            enable_dev_context_override: std::env::var("STUDIO_ENABLE_DEV_CONTEXT_OVERRIDE")
                .ok()
                .and_then(|value| value.parse::<bool>().ok())
                .unwrap_or({{ backend.enable_dev_context_override_default|tojson }}),
        }
    }
}
