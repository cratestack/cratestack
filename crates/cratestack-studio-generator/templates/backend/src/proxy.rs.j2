use axum::{
    Json,
    extract::{Path, RawQuery, State},
    http::{HeaderMap, StatusCode, header},
};

use crate::http::AppState;
use {{ workspace.shared_crate_lib_name }}::{
    StudioContextMetadata, StudioProxyResponse, StudioRequestInfo,
};

pub(crate) async fn list_model(
    State(state): State<AppState>,
    Path((context_key, model_name)): Path<(String, String)>,
    raw_query: RawQuery,
    headers: HeaderMap,
) -> (StatusCode, Json<StudioProxyResponse>) {
    let query = raw_query.0;
    let Some(context) = find_context(&state, &context_key) else {
        return error_response(
            StatusCode::NOT_FOUND,
            "GET",
            format!("{}/api/contexts/{context_key}/models/{model_name}", state.config.mount_path),
            query,
            String::new(),
            format!("unknown context '{context_key}'"),
        );
    };
    let Some(model) = context.models.iter().find(|model| model.name == model_name) else {
        return error_response(
            StatusCode::NOT_FOUND,
            "GET",
            format!("{}/api/contexts/{context_key}/models/{model_name}", state.config.mount_path),
            query,
            String::new(),
            format!("unknown model '{model_name}'"),
        );
    };

    let upstream_url = build_upstream_url(&context.service_url, &model.resource_path, query.as_deref());
    forward_get(
        &state,
        headers,
        &upstream_url,
        format!("{}/api/contexts/{context_key}/models/{model_name}", state.config.mount_path),
        query,
    )
    .await
}

pub(crate) async fn get_model(
    State(state): State<AppState>,
    Path((context_key, model_name, id)): Path<(String, String, String)>,
    headers: HeaderMap,
) -> (StatusCode, Json<StudioProxyResponse>) {
    let Some(context) = find_context(&state, &context_key) else {
        return error_response(
            StatusCode::NOT_FOUND,
            "GET",
            format!("{}/api/contexts/{context_key}/models/{model_name}/{id}", state.config.mount_path),
            None,
            String::new(),
            format!("unknown context '{context_key}'"),
        );
    };
    let Some(model) = context.models.iter().find(|model| model.name == model_name) else {
        return error_response(
            StatusCode::NOT_FOUND,
            "GET",
            format!("{}/api/contexts/{context_key}/models/{model_name}/{id}", state.config.mount_path),
            None,
            String::new(),
            format!("unknown model '{model_name}'"),
        );
    };

    let upstream_url = format!(
        "{}{}/{}",
        context.service_url.trim_end_matches('/'),
        model.resource_path,
        id,
    );
    forward_get(
        &state,
        headers,
        &upstream_url,
        format!("{}/api/contexts/{context_key}/models/{model_name}/{id}", state.config.mount_path),
        None,
    )
    .await
}

pub(crate) async fn invoke_procedure(
    State(state): State<AppState>,
    Path((context_key, procedure_name)): Path<(String, String)>,
    headers: HeaderMap,
    Json(body): Json<serde_json::Value>,
) -> (StatusCode, Json<StudioProxyResponse>) {
    let Some(context) = find_context(&state, &context_key) else {
        return error_response(
            StatusCode::NOT_FOUND,
            "POST",
            format!("{}/api/contexts/{context_key}/procedures/{procedure_name}", state.config.mount_path),
            None,
            String::new(),
            format!("unknown context '{context_key}'"),
        );
    };
    let Some(procedure) = context
        .procedures
        .iter()
        .find(|procedure| procedure.name == procedure_name)
    else {
        return error_response(
            StatusCode::NOT_FOUND,
            "POST",
            format!("{}/api/contexts/{context_key}/procedures/{procedure_name}", state.config.mount_path),
            None,
            String::new(),
            format!("unknown procedure '{procedure_name}'"),
        );
    };

    let upstream_url = format!(
        "{}{}",
        context.service_url.trim_end_matches('/'),
        procedure.route_path,
    );
    let mut request = state.client.post(&upstream_url).json(&body);
    if let Some(value) = headers.get(header::ACCEPT) {
        request = request.header(header::ACCEPT, value);
    }
    if let Some(value) = headers.get(header::AUTHORIZATION) {
        request = request.header(header::AUTHORIZATION, value);
    }
    for (name, value) in &headers {
        if name.as_str().starts_with("x-") {
            request = request.header(name, value);
        }
    }

    let request_info = StudioRequestInfo {
        method: "POST".to_owned(),
        path: format!("{}/api/contexts/{context_key}/procedures/{procedure_name}", state.config.mount_path),
        query: None,
        upstream_url: upstream_url.clone(),
    };

    match request.send().await {
        Ok(response) => {
            let status = response.status();
            let status_code = StatusCode::from_u16(status.as_u16()).unwrap_or(StatusCode::BAD_GATEWAY);
            let body_text = response.text().await.unwrap_or_default();
            let data = if status.is_success() {
                serde_json::from_str(&body_text).ok()
            } else {
                None
            };
            let error = if status.is_success() {
                None
            } else if body_text.is_empty() {
                Some(format!("upstream returned status {}", status.as_u16()))
            } else {
                Some(body_text)
            };
            (
                status_code,
                Json(StudioProxyResponse {
                    ok: status.is_success(),
                    status: status.as_u16(),
                    data,
                    error,
                    request: request_info,
                }),
            )
        }
        Err(error) => error_response(
            StatusCode::BAD_GATEWAY,
            "POST",
            request_info.path,
            None,
            request_info.upstream_url,
            error.to_string(),
        ),
    }
}

fn find_context<'a>(state: &'a AppState, context_key: &str) -> Option<&'a StudioContextMetadata> {
    state.metadata.context(context_key)
}

fn build_upstream_url(service_url: &str, resource_path: &str, query: Option<&str>) -> String {
    let mut upstream_url = format!("{}{}", service_url.trim_end_matches('/'), resource_path);
    if let Some(query) = query.filter(|query| !query.is_empty()) {
        upstream_url.push('?');
        upstream_url.push_str(query);
    }
    upstream_url
}

async fn forward_get(
    state: &AppState,
    headers: HeaderMap,
    upstream_url: &str,
    path: String,
    query: Option<String>,
) -> (StatusCode, Json<StudioProxyResponse>) {
    let mut request = state.client.get(upstream_url);
    if let Some(value) = headers.get(header::ACCEPT) {
        request = request.header(header::ACCEPT, value);
    }
    if let Some(value) = headers.get(header::AUTHORIZATION) {
        request = request.header(header::AUTHORIZATION, value);
    }
    for (name, value) in &headers {
        if name.as_str().starts_with("x-") {
            request = request.header(name, value);
        }
    }

    let request_info = StudioRequestInfo {
        method: "GET".to_owned(),
        path,
        query,
        upstream_url: upstream_url.to_owned(),
    };

    match request.send().await {
        Ok(response) => {
            let status = response.status();
            let status_code = StatusCode::from_u16(status.as_u16()).unwrap_or(StatusCode::BAD_GATEWAY);
            let body = response.text().await.unwrap_or_default();
            let data = if status.is_success() {
                serde_json::from_str(&body).ok()
            } else {
                None
            };
            let error = if status.is_success() {
                None
            } else if body.is_empty() {
                Some(format!("upstream returned status {}", status.as_u16()))
            } else {
                Some(body)
            };
            (
                status_code,
                Json(StudioProxyResponse {
                    ok: status.is_success(),
                    status: status.as_u16(),
                    data,
                    error,
                    request: request_info,
                }),
            )
        }
        Err(error) => error_response(
            StatusCode::BAD_GATEWAY,
            "GET",
            request_info.path,
            request_info.query,
            request_info.upstream_url,
            error.to_string(),
        ),
    }
}

fn error_response(
    status: StatusCode,
    method: &str,
    path: String,
    query: Option<String>,
    upstream_url: String,
    error: String,
) -> (StatusCode, Json<StudioProxyResponse>) {
    (
        status,
        Json(StudioProxyResponse {
            ok: false,
            status: status.as_u16(),
            data: None,
            error: Some(error),
            request: StudioRequestInfo {
                method: method.to_owned(),
                path,
                query,
                upstream_url,
            },
        }),
    )
}
