use serde::{Deserialize, Serialize};

#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]
pub struct StudioMetadata {
    pub name: String,
    pub mount_path: String,
    pub default_context: String,
    pub contexts: Vec<StudioContextMetadata>,
}

impl StudioMetadata {
    pub fn default_context(&self) -> Option<&StudioContextMetadata> {
        self.context(&self.default_context)
            .or_else(|| self.contexts.first())
    }

    pub fn context(&self, key: &str) -> Option<&StudioContextMetadata> {
        self.contexts.iter().find(|context| context.key == key)
    }
}

#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]
pub struct StudioContextMetadata {
    pub key: String,
    pub display_name: String,
    pub service: String,
    pub schema_path: String,
    pub service_url: String,
    pub models: Vec<StudioModel>,
    pub enums: Vec<StudioEnum>,
    pub procedures: Vec<StudioProcedure>,
}

#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]
pub struct StudioModel {
    pub name: String,
    pub display_name: String,
    pub resource_path: String,
    pub primary_key: String,
    pub paged: bool,
    pub scalar_fields: Vec<StudioField>,
    pub relations: Vec<StudioRelation>,
    pub list_columns: Vec<String>,
}

#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]
pub struct StudioField {
    pub name: String,
    pub display_name: String,
    pub type_name: String,
    pub required: bool,
    pub list: bool,
    pub is_json: bool,
    pub enum_name: Option<String>,
    pub enum_values: Vec<String>,
}

#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]
pub struct StudioRelation {
    pub name: String,
    pub target_model: String,
    pub cardinality: String,
}

#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]
pub struct StudioEnum {
    pub name: String,
    pub values: Vec<String>,
}

#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]
pub struct StudioProcedure {
    pub name: String,
    pub display_name: String,
    pub route_path: String,
    pub kind: String,
    pub args_type: Option<String>,
    pub payload_mode: String,
    pub input_fields: Vec<StudioInputField>,
    pub return_type: String,
    pub return_kind: String,
}

#[derive(Debug, Clone, PartialEq, Eq, Serialize, Deserialize)]
pub struct StudioInputField {
    pub name: String,
    pub display_name: String,
    pub type_name: String,
    pub required: bool,
    pub list: bool,
    pub is_json: bool,
    pub is_boolean: bool,
    pub is_number: bool,
    pub enum_name: Option<String>,
    pub enum_values: Vec<String>,
}

#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]
pub struct StudioRequestInfo {
    pub method: String,
    pub path: String,
    pub query: Option<String>,
    pub upstream_url: String,
}

#[derive(Debug, Clone, PartialEq, Serialize, Deserialize)]
pub struct StudioProxyResponse {
    pub ok: bool,
    pub status: u16,
    pub data: Option<serde_json::Value>,
    pub error: Option<String>,
    pub request: StudioRequestInfo,
}

pub fn studio_metadata() -> StudioMetadata {
    serde_json::from_str(include_str!("metadata.json"))
        .expect("generated studio metadata json should deserialize")
}
